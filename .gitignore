# 白名單模式:home 目錄預設全忽略,僅逐項納管指定路徑(待辦36)
/*

# --- 納管:ForAI 文件(含 grafana-overview-gen.py 等) ---
!/workspace
/workspace/*
!/workspace/ForAI

# --- 納管:Ansible config-as-code(待辦48;backups/ 為各節點設定唯讀入庫) ---
!/workspace/ansible

# --- 納管:入口大廳 portal 源檔(待辦49;node_modules/dist/.venv 由 portal/.gitignore 排除) ---
!/workspace/portal

# --- 納管:Switch3F 交換機 UI 參考檔(待辦25;defLang.js=選單/欄位定位用) ---
!/workspace/switch3f

# --- 納管:監控棧維運腳本(待辦21 起;finish-21-nocodb.sh 等) ---
!/workspace/monitoring
# life-chat 生活助理(待辦49)
!/workspace/life-chat
!/workspace/ha-automations
!/workspace/ct-dmz-proxy
!/workspace/ops
# guest-portal 對外唯讀分享站(待辦50;node_modules/dist 由 guest-portal/.gitignore 排除)
!/workspace/guest-portal

# --- 納管:自製腳本 ~/.local/bin(hl-*、homelab-notify.py、watchdog 等) ---
!/.local
/.local/*
!/.local/bin

# --- 納管:life-ops MCP(server.py 等) ---
!/life-ops-mcp

# --- 納管:本檔 ---
!/.gitignore

# --- 全域排除:秘鑰/憑證/暫存(即使位於納管目錄內) ---
snmp-auth.yml
__pycache__/
*.pyc
.env
*.env
*token*
!get_gcal_token.py
*secret*
!scan-secrets.sh
*credential*
*.pem
*.key
id_ed25519*
id_rsa*
/workspace/ct-dmz-proxy/*.deb
