+    /**
+     * Pastes the configured schematic/structure into the limbo world.
+     *
+     * <p>Fail-open: any problem (missing file, unknown type, parse error) is
+     * logged and the limbo stays a bare void world — a bad world file must
+     * never take the whole proxy hostage.</p>
+     */
+    private void pasteWorldFile(Configuration config, VirtualWorld world) {
+        try {
+            doPasteWorldFile(config, world);
+        } catch (Exception e) {
+            // toml4j getters hard-cast TOML values (e.g. `worldFile = true` throws
+            // ClassCastException before any specific handling below can run).
+            logger.error("Failed to paste limbo world file; keeping empty world.", e);
+        }
+    }
+
+    private void doPasteWorldFile(Configuration config, VirtualWorld world) {
+        String pathString = config.getLimboWorldFile();
+        if (pathString == null || pathString.isEmpty()) {
+            return;
+        }
+
+        Path path;
+        try {
+            path = Path.of(pathString);
+        } catch (java.nio.file.InvalidPathException e) {
+            logger.error("Invalid limbo worldFile path '{}'; keeping empty world.", pathString);
+            return;
+        }
+        if (!Files.isRegularFile(path)) {
+            logger.error("Limbo world file '{}' not found; keeping empty world.", pathString);
+            return;
+        }
+
+        BuiltInWorldFileType type;
+        try {
+            type = BuiltInWorldFileType.valueOf(config.getLimboWorldFileType());
+        } catch (IllegalArgumentException e) {
+            logger.error("Unknown limbo worldFileType '{}' (expected SCHEMATIC, WORLDEDIT_SCHEM or STRUCTURE); keeping empty world.",
+                    config.getLimboWorldFileType());
+            return;
+        }
+
+        try {
+            WorldFile worldFile = factory.openWorldFile(type, path);
+            worldFile.toWorld(factory, world,
+                    config.getLimboWorldFileOffsetX(),
+                    config.getLimboWorldFileOffsetY(),
+                    config.getLimboWorldFileOffsetZ(),
+                    Math.max(0, Math.min(15, config.getLimboWorldFileLightLevel())));
+            logger.info("Pasted limbo world file '{}' ({}) at offset ({}, {}, {}).",
+                    pathString, type,
+                    config.getLimboWorldFileOffsetX(),
+                    config.getLimboWorldFileOffsetY(),
+                    config.getLimboWorldFileOffsetZ());
+        } catch (Exception e) {
+            logger.error("Failed to paste limbo world file '{}'; keeping empty world.", pathString, e);
+        }
+    }
+
