# the PVE managed interfaces into external files!

auto lo
iface lo inet loopback

iface nic0 inet manual

iface nic1 inet manual

iface nic2 inet manual

iface nic3 inet manual

auto vmbr0
iface vmbr0 inet static
	address 192.168.31.2/24
	bridge-ports nic0
	bridge-stp off
	bridge-fd 0
	bridge-vlan-aware yes
	bridge-vids 2-4094
	comment legacy rescue IP only (2026-07-05 mig8); no gateway, no service role

source /etc/network/interfaces.d/*

auto vmbr1
iface vmbr1 inet manual
	bridge-ports nic1
	bridge-stp off
	bridge-fd 0
	bridge-vlan-aware yes
	bridge-vids 2-4094

auto vmbr2
iface vmbr2 inet manual
	bridge-ports nic2
	bridge-stp off
	bridge-fd 0
	bridge-vlan-aware yes
	bridge-vids 2-4094

auto vmbr3
iface vmbr3 inet manual
	bridge-ports nic3
	bridge-stp off
	bridge-fd 0
	bridge-vlan-aware yes
	bridge-vids 2-4094

auto vmbr66
iface vmbr66 inet manual
        bridge-ports none
        bridge-stp off
        bridge-fd 0
        comment honeypot isolated bridge

auto vmbr0.10
iface vmbr0.10 inet static
        address 192.168.10.2/24
        gateway 192.168.10.1
        post-up ip route add 192.168.30.3/32 via 192.168.10.1 dev vmbr0.10 || true
        pre-down ip route del 192.168.30.3/32 via 192.168.10.1 dev vmbr0.10 || true
        comment VLAN10 Infra mgmt IP (primary since 2026-07-05 mig8); DXP SMB backup route via VLAN10
